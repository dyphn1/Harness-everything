{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node d:/GitHub/harness-skills/hooks/scripts/rule-of-3.js"
          }
        ],
        "description": "Rule of 3 Circuit Breaker - Prevents micro-error looping",
        "id": "harness:pre:rule-of-3"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node d:/GitHub/harness-skills/hooks/scripts/rule-of-3-tracker.js"
          }
        ],
        "description": "Track error signatures for Rule of 3",
        "id": "harness:post:rule-of-3-tracker"
      }
    ]
  }
}
